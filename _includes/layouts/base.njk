<!DOCTYPE html>
<html lang="{{ language or 'en' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or site.description }}">
  <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
  
  {% set base = site.baseUrl | default("") %}
  <link rel="icon" type="image/png" href="{{ base }}/assets/images/python-logo.png">
  
  <!-- OpenGraph -->
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{% if title %}{{ title }} | {% endif %}{{ site.title }}">
  <meta name="twitter:description" content="{{ description or site.description }}">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ base }}/assets/css/main.css">
  <link rel="stylesheet" href="{{ base }}/assets/css/print.css" media="print">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  {% if stylesheet %}<link rel="stylesheet" href="{{ stylesheet }}">{% endif %}
</head>
<body data-theme="light" data-language="{{ language or 'en' }}">
  {% include "partials/sidebar.njk" %}
  {% include "partials/header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>
  
  {% include "partials/footer.njk" %}
  
  <script src="https://cdn.jsdelivr.net/npm/lunr@2.3.9/lunr.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-core.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
  <script src="https://cdn.jsdelivr.net/pyodide/v0.24.1/full/pyodide.js" defer></script>
  <script>
    window.synonyms = {{ synonyms | dump | safe }};
  </script>
  <script>
    window.BASE_URL = "{{ base }}";
  </script>
  <script src="{{ base }}/assets/js/theme.js" defer></script>
  <script src="{{ base }}/assets/js/mobile-menu.js" defer></script>
  <script src="{{ base }}/assets/js/search.js" defer></script>
  <script src="{{ base }}/assets/js/toc.js" defer></script>
  <script src="{{ base }}/assets/js/code-highlight.js" defer></script>
  <script src="{{ base }}/assets/js/sandbox.js" defer></script>
  <script src="{{ base }}/assets/js/sidebar.js" defer></script>
  {% if script %}<script src="{{ script }}" defer></script>{% endif %}
  <script>
    (function () {
      // Runtime fix: when the site is hosted under a repository sub-path (site.baseUrl),
      // many content files use root-prefixed paths like `/assets/...` or `/ru/...`.
      // This script rewrites anchors, images, and form actions that start with `/`
      // to include the configured BASE_URL so links work on GitHub Pages repo subpaths.
      var base = (window.BASE_URL || "") || "";
      if (!base) return;
      // Normalize base: remove trailing slash if present (we expect base like '/pythonpedia')
      base = base.replace(/\/$/, '');

      function prefixIfRootPath(value) {
        if (!value) return value;
        // Leave protocol-relative and absolute origins alone
        if (value.startsWith('//') || /^[a-zA-Z]+:\/\//.test(value)) return value;
        // Already prefixed with base
        if (value.indexOf(base + '/') === 0) return value;
        // Only transform root-relative paths
        if (value.charAt(0) === '/') return (base + value).replace(/\/{2,}/g, '/');
        return value;
      }

      document.addEventListener('DOMContentLoaded', function () {
        try {
          Array.prototype.forEach.call(document.querySelectorAll('a[href^="/"]'), function (a) {
            var href = a.getAttribute('href');
            a.setAttribute('href', prefixIfRootPath(href));
          });
          Array.prototype.forEach.call(document.querySelectorAll('img[src^="/"]'), function (img) {
            var src = img.getAttribute('src');
            img.setAttribute('src', prefixIfRootPath(src));
          });
          Array.prototype.forEach.call(document.querySelectorAll('form[action^="/"]'), function (f) {
            var act = f.getAttribute('action');
            f.setAttribute('action', prefixIfRootPath(act));
          });
        } catch (e) {
          // Don't let rewriting break the page if something unexpected happens
          console.warn('Base URL rewriting failed', e);
        }
      });
    })();
  </script>
</body>
</html>
